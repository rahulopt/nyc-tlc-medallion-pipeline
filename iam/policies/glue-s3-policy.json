{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3BucketAccess",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::nyc-tlc-dev-raw-519749210589",
                "arn:aws:s3:::nyc-tlc-dev-curated-519749210589",
                "arn:aws:s3:::nyc-tlc-dev-gold-519749210589",
                "arn:aws:s3:::nyc-tlc-dev-reject-519749210589",
                "arn:aws:s3:::nyc-tlc-dev-assets-519749210589"
            ]
        },
        {
            "Sid": "S3ObjectAccess",
            "Effect": "Allow",
            "Action": [
